{
	"name": "wbcomdesigns/buddypress-recaptcha",
	"description": "Complete CAPTCHA solution for WordPress, WooCommerce, BuddyPress, bbPress, and popular form builders.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=7.4",
		"easy-digital-downloads/edd-sl-sdk": "^1.0.0"
	},
	"require-dev": {
		"php-parallel-lint/php-parallel-lint": "^1.3",
		"phpstan/phpstan": "^1.10",
		"szepeviktor/phpstan-wordpress": "^1.3",
		"phpstan/extension-installer": "^1.3",
		"php-stubs/woocommerce-stubs": "^10.6",
		"php-stubs/wp-cli-stubs": "^2.12"
	},
	"repositories": {
		"edd-sl-sdk": {
			"type": "vcs",
			"url": "https://github.com/awesomemotive/edd-sl-sdk"
		}
	},
	"scripts": {
		"lint": "@php ./vendor/bin/parallel-lint --exclude .git --exclude vendor --exclude node_modules .",
		"phpstan": "@php ./vendor/bin/phpstan analyse --level=5 --memory-limit=1G -c phpstan.neon"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"phpstan/extension-installer": true
		}
	}
}
